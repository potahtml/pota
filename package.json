{
	"name": "pota",
	"description": "pota is a small and pluggable Reactive Web Renderer.",
	"version": "0.20.230",
	"author": "Tito Bouzout",
	"homepage": "https://pota.quack.uy/",
	"type": "module",
	"types": "./typescript/exports.d.ts",
	"main": "./src/exports.js",
	"sideEffects": false,
	"exports": {
		"./babel-preset": {
			"require": "./generated/babel-preset.cjs",
			"import": "./babel-preset/babel-preset.js",
			"default": "./babel-preset/babel-preset.js"
		},
		"./jsx-runtime": {
			"types": "./typescript/jsx/runtime.d.ts",
			"default": "./src/jsx/jsx-runtime.js"
		},
		"./jsx-dev-runtime": {
			"types": "./typescript/jsx/runtime.d.ts",
			"default": "./src/jsx/jsx-runtime.js"
		},
		"./xml": {
			"types": "./generated/types/core/xml.d.ts",
			"default": "./src/core/xml.js"
		},
		"./components": {
			"types": "./generated/types/components/@main.d.ts",
			"default": "./src/components/@main.js"
		},
		"./use/*": {
			"types": "./generated/types/use/*.d.ts",
			"default": "./src/use/*.js"
		},
		"./store": {
			"types": "./generated/types/lib/store.d.ts",
			"default": "./src/lib/store.js"
		},
		".": {
			"types": "./typescript/exports.d.ts",
			"default": "./src/exports.js"
		}
	},
	"imports": {
		"#test": "./tools/test-runner/test.js",
		"#type/*": "./typescript/private/*"
	},
	"scripts": {
		"dev": "npm run clean && (npm run build:ts || true) && node tools/watch.js",
		"clean": "rm -Rf generated/*",
		"build:ts": "tsc",
		"build:babel-preset": "rollup -c tools/babel-preset/rollup.config.js",
		"build:generate": "node tools/generate.js",
		"watch:ts": "tsc -w",
		"watch:ts-tests": "tsc -p tests/tsconfig.json -w",
		"watch:ts-babel-preset": "tsc -p babel-preset/tsconfig.json -w",
		"watch:babel-preset": "rollup -c tools/babel-preset/rollup.config.js -w",
		"watch:generate": "node tools/generate.js -w",
		"watch:test": "node tools/test-runner/runner.js -w -q",
		"test": "npm run test:types && npm run test:api -- --no-clear -q && npm run test:babel-preset",
		"test:api": "node tools/test-runner/runner.js",
		"test:babel-preset": "node tools/babel-preset/test/runner.js",
		"test:types": "npm run test:ts && npm run test:ts-tests && npm run test:ts-babel-preset",
		"test:ts": "tsc",
		"test:ts-tests": "tsc -p tests/tsconfig.json",
		"test:ts-babel-preset": "tsc -p babel-preset/tsconfig.json",
		"release": "npm run test && node tools/release.js",
		"format": "prettier . -w --config=./package.json --no-editorconfig --plugin=prettier-plugin-jsdoc"
	},
	"dependencies": {
		"colorjs.io": "^0.6.1",
		"csstype": "^3.2.3",
		"parse5": "^8.0.0"
	},
	"peerDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/helper-module-imports": "^7.28.6",
		"@babel/plugin-syntax-jsx": "^7.28.6"
	},
	"devDependencies": {
		"@babel/preset-typescript": "^7.28.5",
		"@babel/standalone": "^7.29.2",
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"@types/babel__core": "^7.20.5",
		"@types/babel__helper-module-imports": "^7.18.3",
		"@types/babel__helper-plugin-utils": "^7.10.3",
		"@types/node": "^25.5.0",
		"prettier-plugin-jsdoc": "^1.8.0",
		"puppeteer": "^24.40.0",
		"rollup": "^4.60.0",
		"typescript": "^6.0.2"
	},
	"test": {
		"dirs": ["tests/api/"],
		"extensions": [".jsx", ".tsx", ".ts"],
		"watch": ["src/", "babel-preset/"],
		"ignore": [],
		"port": 7357,
		"timeout": 8000,
		"concurrency": 16
	},
	"prettier": {
		"printWidth": 70,
		"useTabs": true,
		"semi": false,
		"singleQuote": true,
		"quoteProps": "as-needed",
		"jsxSingleQuote": false,
		"trailingComma": "all",
		"bracketSpacing": true,
		"bracketSameLine": false,
		"arrowParens": "avoid",
		"proseWrap": "always",
		"endOfLine": "lf",
		"singleAttributePerLine": false
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/potahtml/pota.git"
	},
	"keywords": [
		"reactive",
		"renderer",
		"jsx",
		"signal",
		"signals",
		"store",
		"ui",
		"dom",
		"babel-preset",
		"solid"
	],
	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/titoBouzout"
		},
		{
			"type": "opencollective",
			"url": "https://opencollective.com/tito-bouzout"
		}
	]
}
