{
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "generated/types",

		"declaration": true,
		// helps to click "implementation" and go to the source code
		"declarationMap": true,
		"emitDeclarationOnly": true,
		// "preserveWatchOutput": true,
		"pretty": false,

		"allowJs": true,
		"checkJs": true,
		"strict": true,
		"noImplicitAny": false,
		// `true` breaks inference
		"strictNullChecks": false,
		"skipLibCheck": true,
		"resolveJsonModule": true,

		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ESNext",
		"lib": ["ESNext", "DOM"],

		"jsx": "preserve",
		"jsxImportSource": "pota",

		"types": ["./typescript/jsx.d.ts"]
	},
	"include": ["src"],
	"files": ["typescript/RouterContext.d.ts"],
	"exclude": [
		"node_modules"
	]
}
